# Telegram Bot
BOT_TOKEN=your-telegram-bot-token
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=random-secret-string

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=botshop
DB_PASSWORD=botshop_pass
DB_NAME=botshop

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Binance Pay (can also be configured via Admin panel)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Admin
ADMIN_TELE_IDS=123456789,987654321
ADMIN_JWT_SECRET=your-jwt-secret-here
ADMIN_SESSION_HOURS=2

# Server
PORT=8080
ENV=development

# Ngrok
NGROK_AUTHTOKEN=
NGROK_DOMAIN=refreshful-shantel-symphonically.ngrok-free.dev